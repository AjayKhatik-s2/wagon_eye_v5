# WagonEye train-extraction producer environment overrides.
# Copy to deploy/wagon-eye-extraction.env and edit.  All values are optional;
# unset = the production default baked into extraction/driver.py.

# ---- AWS ----
WAGONEYE_S3_REGION=ap-south-1
# AWS_REGION is also honored. Prefer an EC2 instance IAM role over static keys.

# ---- Extraction classify models (NOT the inspection models) ----
# Drop side_classification.pt (sides) and top_classification.pt (tops) here.
# These are the EXTRACTION classifiers (empty_track / wagon / engine / ...),
# which may DIFFER from models/reconstruction/side_classification.pt used by
# Stage 1 -- keep them in their own dir to avoid a filename collision.
WAGONEYE_EXTRACTION_MODELS_DIR=/opt/wagon_eye_v4/models/extraction

# ---- Poll cadence ----
WAGONEYE_EXTRACTION_POLL_INTERVAL=60

# ---- Buckets (defaults reproduce production; override per deployment) --------
# Global override for all cameras is not offered for buckets (they are per
# camera); use the per-camera overrides below if your layout differs.
# WAGONEYE_EXTRACTION_RIGHT_UP_RAW_BUCKET=biro-wagon-raw-video-copy/camera_CCTV_HZBN_DHN_2_RIGHT_UP
# WAGONEYE_EXTRACTION_RIGHT_UP_TRIMMED_BUCKET=biro-wagon-pre-processed-video-copy/camera_CCTV_HZBN_DHN_2_RIGHT_UP
# WAGONEYE_EXTRACTION_LEFT_UP_RAW_BUCKET=biro-wagon-raw-video-copy/camera_CCTV_HZBN_DHN_1_LEFT_UP
# WAGONEYE_EXTRACTION_LEFT_UP_TRIMMED_BUCKET=biro-wagon-pre-processed-video-copy/camera_CCTV_HZBN_DHN_1_LEFT_UP
# WAGONEYE_EXTRACTION_RIGHT_UP_TOP_RAW_BUCKET=biro-wagon-raw-video-copy/camera_CCTV_HZBN_DHN_5_RIGHT_TOP
# WAGONEYE_EXTRACTION_RIGHT_UP_TOP_TRIMMED_BUCKET=biro-wagon-pre-processed-video-copy/camera_CCTV_HZBN_DHN_5_RIGHT_TOP
# WAGONEYE_EXTRACTION_LEFT_UP_TOP_RAW_BUCKET=biro-wagon-raw-video-copy/camera_CCTV_HZBN_DHN_6_LEFT_TOP
# WAGONEYE_EXTRACTION_LEFT_UP_TOP_TRIMMED_BUCKET=biro-wagon-pre-processed-video-copy/camera_CCTV_HZBN_DHN_6_LEFT_TOP

# ---- Extractor tuning (defaults mirror the V4 per-camera yaml) --------------
# WAGONEYE_EXTRACTION_MIN_TRAIN_DURATION=40
# WAGONEYE_EXTRACTION_ANALYSIS_FRAME_STRIDE=15

# ---- Local processed-key ledger (restart-safe dedup) ------------------------
# WAGONEYE_EXTRACTION_STATE_DIR=/opt/wagon_eye_v4/logs/extraction_state
