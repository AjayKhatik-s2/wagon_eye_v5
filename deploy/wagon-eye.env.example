# WagonEye v4 environment overrides.
#
# Copy to deploy/wagon-eye.env and edit as needed, then point the systemd unit's
# EnvironmentFile= at it.  EVERY variable is optional -- unset means the
# pre-migration default shown below, so an empty file reproduces the original
# behaviour exactly.  Uncomment only what you need to change.
#
# systemd EnvironmentFile syntax: KEY=value, one per line, no `export`, no quotes
# needed unless the value contains spaces.

# ---- Filesystem paths (relative values resolve against the repo root) -------
# WAGONEYE_WORKSPACE_ROOT=/data/wagon_eye/batch_outputs
# WAGONEYE_MODELS_DIR=/data/wagon_eye/models
# WAGONEYE_RECON_MODELS_DIR=/data/wagon_eye/models/reconstruction
# WAGONEYE_FEAT_MODELS_DIR=/data/wagon_eye/models/features
# WAGONEYE_LOCAL_INPUTS_DIR=/data/wagon_eye/local_inputs
# WAGONEYE_LOG_DIR=/var/log/wagon_eye
# WAGONEYE_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# ---- Inference device -------------------------------------------------------
# auto-detect if unset: CUDA when available, else CPU.  Force with:
# WAGONEYE_DEVICE=cuda
# WAGONEYE_DEVICE=cpu

# ---- S3 storage architecture (three buckets) --------------------------------
# Defaults (shown) already implement the architecture; override only to change it.
# WAGONEYE_S3_REGION=ap-south-1
#
# OUTPUT bucket: ALL inspection outputs (reports/ dashboard/ archive/ + state).
# WAGONEYE_S3_OUTPUT_BUCKET=end-results
# WAGONEYE_S3_REPORTS_PREFIX=reports        # reports/<batch_key>/*.pdf,*.json
# WAGONEYE_S3_DASHBOARD_PREFIX=dashboard    # dashboard/<camera_folder>/<date>/*.json
# WAGONEYE_S3_ARCHIVE_PREFIX=archive        # archive/<batch_key>/... (tree+manifest+evidence)
# WAGONEYE_S3_STATE_KEY=processed_batches.json     # duplicate-processing guard (output bucket root)
#
# INPUT: master_runner --auto discovers TRIMMED clips in complete-train.
# WAGONEYE_S3_INPUT_BUCKET=complete-train
# WAGONEYE_S3_INPUT_PREFIXES=camera_CCTV_HZBN_DHN_1_LEFT_UP/,camera_CCTV_HZBN_DHN_2_RIGHT_UP/,camera_CCTV_HZBN_DHN_5_RIGHT_TOP/,camera_CCTV_HZBN_DHN_6_LEFT_TOP/
#
# Buckets the extraction step uses:
# WAGONEYE_S3_RAW_BUCKET=biro-wagon-raw-video-copy      # raw camera recordings only
# WAGONEYE_S3_TRIMMED_BUCKET=complete-train             # extraction output == inspection input

# ---- Single-process end-to-end (raw -> reports in ONE `--auto` process) ------
# When true (default), `master_runner --auto` runs the raw->trimmed extraction
# sweep IN-PROCESS at the top of each poll tick, BEFORE complete-train discovery,
# so one `python -m orchestrator.master_runner --auto` owns the whole flow:
#   RAW bucket -> extraction/trim -> complete-train -> reconstruction -> ... -> end-results.
# No separate train_extraction producer service (and no wagon-eye-extraction.service)
# is required.  Extraction needs the classify models under models/extraction/
# (side_classification.pt, top_classification.pt); if they are absent the sweep
# logs an error per camera and the tick still processes whatever is already in
# complete-train.  Set to false (or pass --skip-extraction) to run the classic
# two-service topology instead.
# WAGONEYE_AUTO_RUN_EXTRACTION=true
#
# Extraction classify-model dir (only needed when AUTO_RUN_EXTRACTION is on):
# WAGONEYE_EXTRACTION_MODELS_DIR=/data/wagon_eye/models/extraction
#
# Dashboard payload bucket defaults to the OUTPUT bucket (end-results/dashboard/).
# Override only if the dashboard reads a separate bucket (back-compat):
# WAGONEYE_INSPECTION_JSON_BUCKET=end-results

# ---- Report microservice + email --------------------------------------------
# WAGONEYE_UPLOAD_API_URL=https://reports-api.suvidhaen.com/api/upload-pdf
# WAGONEYE_EMAIL_API_URL=https://ms-pnr-location-notification-api.suvidhaen.com/notification_microservice/send-email
# WAGONEYE_PRODUCT_NAME=CCTV-WagonEye-CombinedReports
# WAGONEYE_EMAIL_RECEIVER=ops@example.com
# WAGONEYE_EMAIL_RECEIVER_CC=lead@example.com,qa@example.com

# ---- AWS credentials --------------------------------------------------------
# Prefer an EC2 instance IAM role (no keys needed).  If you must use static
# keys, set them here (or better, in ~/.aws/credentials):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=ap-south-1

# ---- Incremental (asynchronous-camera) lifecycle ----------------------------
# The four camera videos for one train do NOT arrive together.  The pipeline
# waits for the RIGHT_UP master, opens a short support-fusion window (armed the
# moment RIGHT_UP arrives) so support cameras can improve Stage-1 gap recovery,
# then SEALS an immutable GlobalTrainState from RIGHT_UP + whatever support is
# present.  Late cameras attach features to the sealed wagons WITHOUT re-running
# Stage 1 or renumbering wagons.  Defaults below reproduce sane production behaviour.
#
# How long (from first-seen) to wait for the RIGHT_UP master before it is "late":
# WAGONEYE_MASTER_WAIT_MINUTES=10
# Short window AFTER RIGHT_UP arrives to collect support cameras, then seal.
# When it expires we seal from RIGHT_UP + present support -- we do NOT wait for
# the final deadline.
# WAGONEYE_SUPPORT_FUSION_WAIT_MINUTES=3
# Hard close (from first-seen): still-missing cameras become CAMERA_MISSING_FINAL
# and the batch finalizes as COMPLETED_PARTIAL.  NOT an implicit master deadline.
# Must be >= SUPPORT_FUSION_WAIT_MINUTES.
# WAGONEYE_FINAL_CAMERA_WAIT_MINUTES=30
#
# If RIGHT_UP never arrives: the batch stays WAITING_FOR_MASTER until the hard
# deadline, then closes FAILED_NO_GLOBAL_STATE (no report, no email).  LEFT_UP
# fallback master is EXPERIMENTAL and disabled -- side_classification.pt is a
# RIGHT_UP model and is unvalidated on LEFT_UP:
# WAGONEYE_ENABLE_LEFT_UP_FALLBACK_MASTER=false
#
# Interim (pre-closure) reports are regenerated on disk as cameras arrive but are
# LOCAL-ONLY by default: exactly one upload + one email happens at closure.
# WAGONEYE_GENERATE_INTERIM_REPORTS=true
# WAGONEYE_UPLOAD_INTERIM_REPORTS=false   # requires GENERATE_INTERIM_REPORTS=true
# WAGONEYE_EMAIL_INTERIM_REPORTS=false    # requires GENERATE_INTERIM_REPORTS=true
#
# A camera that shows up AFTER a batch is terminal is logged and ignored by
# default; the sealed report is never reopened:
# WAGONEYE_LATE_CAMERA_POLICY=IGNORE
#
# Active-batch scheduler poll cadence (seconds) and manifest S3 prefix (empty ->
# train_batch/<key>/manifest.json):
# WAGONEYE_ACTIVE_BATCH_POLL_INTERVAL=60
# WAGONEYE_MANIFEST_S3_PREFIX=
